{
  "name": "ROS 2 Kilted & PlotJuggler",
  "dockerComposeFile": "docker-compose.yml",
  "service": "ros-dev",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-vscode.cpptools",
        "twxs.cmake",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteUser": "rosuser",
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}